# Discord webhook for the #smart-money-poly channel (REQUIRED for non-dry-run smart-money job)
DISCORD_WEBHOOK_URL=

# Optional: separate channel for the daily snapshot. If unset, falls back to DISCORD_WEBHOOK_URL.
DAILY_SNAPSHOT_DISCORD_WEBHOOK_URL=

# X (Twitter) v2 OAuth1.0a user-context credentials. Required only if
# daily_snapshot.enable_x is true and you're not running --dry-run.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Translation provider keys (only the one matching settings.yaml
# daily_snapshot.jp_translation_provider needs to be set):
#   gemini     → GEMINI_API_KEY (free tier 1500 RPD; aistudio.google.com/apikey)
#   anthropic  → ANTHROPIC_API_KEY (paid)
# If neither is set, the snapshot falls back to truncated English question text.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: identify your bot to Polymarket's public APIs (no key needed).
POLYMARKET_USER_AGENT=polymarket-smart-money/0.1

LOG_LEVEL=INFO
DB_PATH=./data/smart_money.db
DRY_RUN=false
